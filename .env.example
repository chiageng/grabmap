NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# GrabMaps API — key usually starts with "bm_"
# Used both by the MapLibre style fetch (client) and the /api/pulse backend (server)
NEXT_PUBLIC_GRABMAPS_API_KEY=
GRABMAPS_API_KEY=
GRABMAPS_BASE_URL=https://maps.grab.com
NEXT_PUBLIC_GRABMAPS_BASE_URL=https://maps.grab.com

# Default map center (Singapore)
NEXT_PUBLIC_DEFAULT_LAT=1.3521
NEXT_PUBLIC_DEFAULT_LNG=103.8198
NEXT_PUBLIC_DEFAULT_COUNTRY=SGP

# Anthropic (for AI Pulse Summary)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
